{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "allow",
      "grep *": "allow"
    },
    "edit": {
      "*": "allow",
      "packages/web/src/content/docs/*.mdx": "allow"
    },
    "read": {
      "*": "allow",
      "config/.env": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",

  }
}